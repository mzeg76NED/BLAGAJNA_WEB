# Cloudflare Pages / Functions
BACKEND_MODE=legacy
APP_ENV=development
APP_VERSION=cloudflare-migration-0.1.0

# Supabase
SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-only-in-server-env
SUPABASE_PROJECT_REF=jxlztevomgwhttmawblz

# Optional server-side DB ping for /api/status.
STATUS_DB_CHECK=false

# Legacy Apps Script bridge, used only while BACKEND_MODE=legacy.
LEGACY_APPS_SCRIPT_URL=https://script.google.com/macros/s/replace/deploy

# Business defaults
APP_TIMEZONE=Europe/Belgrade
APP_SESSION_HOURS=12
